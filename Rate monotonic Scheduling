
#include <stdio.h>
#include <math.h>

int main() {
    int n;

    printf("Enter number of tasks: ");
    scanf("%d", &n);

    int exec[n], period[n];

    for (int i = 0; i < n; i++) {
        printf("Task %d execution time and period: ", i+1);
        scanf("%d %d", &exec[i], &period[i]);
    }

    // Sort by period (RM priority)
    for (int i = 0; i < n-1; i++) {
        for (int j = i+1; j < n; j++) {
            if (period[i] > period[j]) {
                // swap period
                int temp = period[i];
                period[i] = period[j];
                period[j] = temp;

                // swap exec accordingly
                temp = exec[i];
                exec[i] = exec[j];
                exec[j] = temp;
            }
        }
    }

    printf("\nTask\tExec\tPeriod\n");
    for (int i = 0; i < n; i++) {
        printf("T%d\t%d\t%d\n", i+1, exec[i], period[i]);
    }

    // Utilization
    float u = 0;
    for (int i = 0; i < n; i++) {
        u += (float)exec[i] / period[i];
    }

    float bound = n * (pow(2, 1.0/n) - 1);

    printf("\nUtilization = %.2f\n", u);
    printf("Bound = %.2f\n", bound);

    if (u <= bound)
        printf("Schedulable\n");
    else
        printf("Not guaranteed\n");

    return 0;
}
