#include<stdio.h>

int main(){
    int n ,i,j,time=0,highest;
    int at[10],bt[10],pr[10],ct[10],wt[10],tat[10],done[10]={0};
    float s1=0.0,s2=0.0;
    printf(" enter the number of processes\n: ");
    scanf("%d",&n);
    for(i=0;i<n;i++){

        printf("enter AT BT PR for P%d: ",i+1);
        scanf("%d %d %d",&at[i],&bt[i],&pr[i]);
    }
    int completed=0;
    while(completed<n){
        highest=-1;
        for(i=0;i<n;i++){
            if(at[i]<=time && done[i]==0){
                if(highest==-1 || pr[i]<pr[highest]){
                    highest=i;
                }
            }
        }
        if(highest==-1){
            time++;
        }
        else{
            time+=bt[highest];
            ct[highest]=time;
            tat[highest]=ct[highest]-at[highest];
            wt[highest]=tat[highest]-bt[highest];
            done[highest]=1;
            completed++;
        }
    }
    for(i=0;i<n;i++){
        printf("\n P%d  at->%d  bt->%d  ct->%d  pr->%d  tat->%d  wt->%d",i+1,at[i],bt[i],ct[i],pr[i],tat[i],wt[i]);
        s1=s1+tat[i];
        s2=s2+wt[i];
    }
    printf(" \n the average turnaround time:%f",s1/n);
    printf("\n the average waiting time: %f",s2/n);
    return 0;
}
