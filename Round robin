
#include<stdio.h>

int main()
{
    int n,i,time=0,tq;
    int at[10],bt[10],rt[10],ct[10],wt[10],tat[10];
    int completed=0;
    float s1=0,s2=0;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        printf("Enter AT and BT for P%d: ",i+1);
        scanf("%d%d",&at[i],&bt[i]);
        rt[i]=bt[i];
    }

    printf("Enter Time Quantum: ");
    scanf("%d",&tq);

    while(completed<n)
    {
        int executed=0;

        for(i=0;i<n;i++)
        {
            if(at[i]<=time && rt[i]>0)
            {
                executed=1;
                if(rt[i]>tq)
                {
                    time+=tq;
                    rt[i]-=tq;
                }
                else
                {
                    time+=rt[i];
                    rt[i]=0;
                    completed++;

                    ct[i]=time;
                    tat[i]=ct[i]-at[i];
                    wt[i]=tat[i]-bt[i];

                    s1+=wt[i];
                    s2+=tat[i];
                }
            }
        }

        if(executed==0)
            time++;
    }

    printf("\nProcess\tAT\tBT\tCT\tTAT\tWT\n");

    for(i=0;i<n;i++)
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
        i+1,at[i],bt[i],ct[i],tat[i],wt[i]);

    printf("\nAverage Waiting Time = %.2f",s1/n);
    printf("\nAverage Turnaround Time = %.2f",s2/n);

    return 0;
}
